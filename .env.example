# LLM Configuration
LLM_PROVIDER=huggingface
HF_API_KEY=hf_your_token_here
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama base URL (used if LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Configuration
EMBEDDING_PROVIDER=huggingface

# Embedding model name
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Qdrant Configuration
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io

# Qdrant API key
QDRANT_API_KEY=

# Default Qdrant collection name
QDRANT_COLLECTION=documents

# Ingestion Configuration (Chunk size in tokens)
CHUNK_SIZE=512

# Overlap between consecutive chunks in tokens
CHUNK_OVERLAP=64

# Retrieval Configuration (Number of top results to retrieve per query)
RETRIEVER_K=5

# Agent Configuration (Maximum number of ReAct loop steps)
AGENT_MAX_STEPS=10

# Logging Configuration (Log level: "error", "warn", "info", or "debug")
LOG_LEVEL=info

# Environment (Node environment: "development", "production", or "test")
NODE_ENV=development
