# LLM Configuration
LLM_PROVIDER=huggingface
HF_API_KEY=hf_your_token_here
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama base URL (used if LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Configuration
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Qdrant Configuration
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Ingestion Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval Configuration
RETRIEVER_K=5

# Agent Configuration
AGENT_MAX_STEPS=10

# Logging
LOG_LEVEL=info
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pro-rag

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
